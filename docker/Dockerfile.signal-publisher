FROM rust:1.88 as builder
WORKDIR /app
COPY . .
RUN cargo build --release -p signal-publisher

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/signal-publisher /usr/local/bin/signal-publisher
CMD ["signal-publisher"]
