FROM rust:1.88 as builder
WORKDIR /app
COPY . .
RUN cargo build --release -p manipulation-detector

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/manipulation-detector /usr/local/bin/manipulation-detector
CMD ["manipulation-detector"]
